# No API key required -- this app runs fully locally via Ollama + Sentence Transformers.
# These are optional overrides (defaults shown); only set them if you're running
# Ollama on a different host/port, want a different local model, or need to
# lower the context window on a memory-constrained machine.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_NUM_CTX=12288
